generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String             @id @default(cuid())
  fullName       String?
  email          String             @unique
  phoneNumber    String?
  backupEmail    String?            @unique
  recoveryPhoneNumber String?
  username       String             @unique
  passwordHash   String
  passwordUpdatedAt DateTime @default(now())
  sessionVersion Int @default(1)
  city           String?
  state          String?
  country        String?
  lastOnLinesAt  String?
  lastService    String?
  lastServiceWhen String?
  iasStatus      String?
  iasNumber      String?
  subscriptionTier String @default("FREE")
  role           String @default("MEMBER")
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  profile        Profile?
  posts          Post[]
  streamPosts    Post[]             @relation("ProfileStreamOwner")
  comments       Comment[]
  reactions      Reaction[]
  sentRequests   FriendRequest[]    @relation("SentRequests")
  receivedRequests FriendRequest[]  @relation("ReceivedRequests")
  friendsA       Friendship[]       @relation("FriendshipA")
  friendsB       Friendship[]       @relation("FriendshipB")
  messages       Message[]
  threadsA       MessageThread[]    @relation("ThreadUserA")
  threadsB       MessageThread[]    @relation("ThreadUserB")
  messagePresence MessageThreadPresence[]
  pushSubscriptions PushSubscription[]
  groupsOwned    Group[]            @relation("GroupOwner")
  groupMemberships GroupMember[]
  notifications  Notification[]
  alerts         Alert[]
  alertSubscriptions AlertSubscription[]
  feedPreference UserFeedPreference?
  mutedUsers     MutedUser[]        @relation("MutedByUser")
  mutedBy        MutedUser[]        @relation("MutedTargetUser")
  blockedUsers   UserBlock[]        @relation("UserBlocks")
  blockedBy      UserBlock[]        @relation("UserBlockedBy")
  mutedTopics    MutedTopic[]
  followedTopics FollowedTopic[]
  albums         PhotoAlbum[]
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  twoFactorConfig TwoFactorConfig?
  createdGroupEvents GroupEvent[]
  createdEvents      Event[]
  eventInvitations   EventInvitation[]
  eventModerators    EventModerator[]   @relation("EventModerators")
  eventModeratorGrants EventModerator[] @relation("EventModeratorGrants")
  groupForumThreads  GroupForumThread[]
  groupForumPosts    GroupForumPost[]
  groupDocuments     GroupDocument[]
  groupPhotos        GroupPhoto[]
  groupJoinRequests  GroupJoinRequest[]
  pollVotes          PostPollVote[]
  photoComments      PhotoComment[]
  following          UserFollow[]      @relation("UserFollowing")
  followers          UserFollow[]      @relation("UserFollowers")
  keyMaterial        UserKeyMaterial?
  securityEvents     AuthSecurityEvent[]
  mediaTags          UserMediaTag[]
  uploadAssets       UserUploadAsset[]
  bazaarListings     BazaarListing[]
  jobListings        JobListing[]
  auditorListings    AuditorListing[]
  moderatorActions   ModeratorActionLog[]
  messageModerationEvents MessageModerationEvent[]
  petitions          AdminPetition[]
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  displayName       String
  headline          String?
  bio               String?
  detailedBioJson   String?
  location          String?
  interests         String?
  relationshipStatus String?
  avatarUrl         String?
  bannerUrl         String?
  scientologyTrainingLevel String?
  scientologyCaseLevel String?
  scientologySuccessStory String?
  scientologyAchievements String?
  scientologyGoals String?
  scientologyProjects String?
  scientologyAdditionalCoursesJson String?
  scientologyIncludeOnResume Boolean @default(false)
  scientologyVisible Boolean @default(false)
  resumeJson         String?
  resumeVisible      Boolean @default(false)
  themeId           String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme             Theme?   @relation(fields: [themeId], references: [id])
}

model Theme {
  id                String   @id @default(cuid())
  key               String   @unique
  name              String   @unique
  background        String
  accentColor       String
  cardStyle         String
  headerStyle       String
  buttonStyle       String
  fontPairing       String
  patternAsset      String?
  profiles          Profile[]
}

model Post {
  id                String   @id @default(cuid())
  authorId          String
  streamOwnerId     String?
  approvalStatus    String   @default("APPROVED")
  type              String   @default("TEXT")
  allowReshare      Boolean  @default(true)
  commentsLocked    Boolean  @default(false)
  content           String
  audience          String   @default("ALL")
  imageUrl          String?
  mediaUrlsJson     String?
  topic             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  groupId           String?
  parentPostId      String?
  author            User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  streamOwner       User?    @relation("ProfileStreamOwner", fields: [streamOwnerId], references: [id], onDelete: SetNull)
  comments          Comment[]
  reactions         Reaction[]
  group             Group?   @relation(fields: [groupId], references: [id])
  poll              PostPoll?
  @@index([createdAt, id])
  @@index([authorId, createdAt])
  @@index([groupId, createdAt])
  @@index([audience, createdAt])
}

model PostPoll {
  id           String   @id @default(cuid())
  postId       String   @unique
  question     String
  allowMulti   Boolean  @default(false)
  closesAt     DateTime?
  createdAt    DateTime @default(now())
  post         Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  options      PostPollOption[]
  votes        PostPollVote[]
}

model PostPollOption {
  id         String   @id @default(cuid())
  pollId     String
  label      String
  createdAt  DateTime @default(now())
  poll       PostPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes      PostPollVote[]
}

model PostPollVote {
  id         String   @id @default(cuid())
  pollId     String
  optionId   String
  voterId    String
  createdAt  DateTime @default(now())
  poll       PostPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option     PostPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter      User     @relation(fields: [voterId], references: [id], onDelete: Cascade)
  @@unique([optionId, voterId])
  @@index([pollId, voterId])
}

model Comment {
  id         String   @id @default(cuid())
  postId     String
  authorId   String
  parentCommentId String?
  content    String
  mediaUrlsJson String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  @@index([postId, createdAt])
  @@index([postId, parentCommentId, createdAt])
  @@index([authorId, createdAt])
}

model Reaction {
  id         String   @id @default(cuid())
  postId     String
  userId     String
  type       String
  createdAt  DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([postId, userId, type])
}

model FriendRequest {
  id          String              @id @default(cuid())
  senderId    String
  receiverId  String
  status      String              @default("PENDING")
  createdAt   DateTime            @default(now())
  sender      User                @relation("SentRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User                @relation("ReceivedRequests", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Friendship {
  id          String   @id @default(cuid())
  userAId     String
  userBId     String
  createdAt   DateTime @default(now())
  userA       User     @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User     @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)
  @@unique([userAId, userBId])
  @@index([userAId, createdAt])
  @@index([userBId, createdAt])
}

model MessageThread {
  id          String   @id @default(cuid())
  userAId     String
  userBId     String
  updatedAt   DateTime @updatedAt
  userA       User     @relation("ThreadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User     @relation("ThreadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages    Message[]
  presences   MessageThreadPresence[]
  moderationEvents MessageModerationEvent[]
}

model Message {
  id          String   @id @default(cuid())
  threadId    String
  senderId    String
  clientMessageId String?
  body        String
  editedAt    DateTime?
  hiddenBySenderAt DateTime?
  readAt      DateTime?
  createdAt   DateTime @default(now())
  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  moderationEvents MessageModerationEvent[]
  @@index([threadId, createdAt])
  @@index([senderId, createdAt])
  @@unique([threadId, senderId, clientMessageId])
}

model MessageThreadPresence {
  id          String   @id @default(cuid())
  threadId    String
  userId      String
  isTyping    Boolean  @default(false)
  lastTypedAt DateTime?
  lastSeenAt  DateTime?
  updatedAt   DateTime @updatedAt
  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([threadId, userId])
  @@index([threadId, updatedAt])
  @@index([userId, updatedAt])
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  deviceId    String?
  endpoint    String
  p256dh      String?
  auth        String?
  enabled     Boolean  @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, endpoint])
  @@index([userId, enabled, updatedAt])
}

model MessageModerationEvent {
  id          String   @id @default(cuid())
  threadId    String
  messageId   String
  actorUserId String
  action      String
  reason      String?
  createdAt   DateTime @default(now())
  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message     Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  actor       User    @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  @@index([threadId, createdAt])
  @@index([messageId, createdAt])
  @@index([actorUserId, createdAt])
}

model Group {
  id          String          @id @default(cuid())
  name        String
  description String?
  visibility  String          @default("PUBLIC")
  joinMode    String          @default("OPEN")
  ownerId     String
  createdAt   DateTime        @default(now())
  owner       User            @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     GroupMember[]
  joinRequests GroupJoinRequest[]
  posts       Post[]
  events      GroupEvent[]
  threads     GroupForumThread[]
  documents   GroupDocument[]
  photos      GroupPhoto[]
  photoAlbums GroupPhotoAlbum[]
}

model GroupJoinRequest {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  reviewedAt  DateTime?
  reviewedById String?
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([groupId, userId])
  @@index([groupId, status, createdAt])
}

model Event {
  id            String   @id @default(cuid())
  creatorId     String
  title         String
  description   String?
  startsAt      DateTime
  endsAt        DateTime?
  locationName  String?
  latitude      Float?
  longitude     Float?
  googleMapsUrl String?
  visibility    String   @default("PUBLIC")
  createdAt     DateTime @default(now())
  creator       User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  invitations   EventInvitation[]
  moderators    EventModerator[]
  @@index([startsAt, createdAt])
  @@index([creatorId, createdAt])
}

model EventInvitation {
  id         String   @id @default(cuid())
  eventId    String
  inviteeId  String
  status     String   @default("INVITED")
  createdAt  DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitee    User     @relation(fields: [inviteeId], references: [id], onDelete: Cascade)
  @@unique([eventId, inviteeId])
  @@index([inviteeId, status, createdAt])
}

model EventModerator {
  id          String   @id @default(cuid())
  eventId     String
  userId      String
  grantedById String
  createdAt   DateTime @default(now())
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User     @relation("EventModerators", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy   User     @relation("EventModeratorGrants", fields: [grantedById], references: [id], onDelete: Cascade)
  @@unique([eventId, userId])
  @@index([eventId, createdAt])
  @@index([userId, createdAt])
}

model BazaarListing {
  id          String   @id @default(cuid())
  sellerId    String
  title       String
  description String?
  price       Float
  currency    String   @default("USD")
  location    String?
  category    String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  @@index([status, createdAt])
  @@index([location, createdAt])
  @@index([category, createdAt])
}

model GroupMember {
  id          String   @id @default(cuid())
  groupId     String
  userId      String
  createdAt   DateTime @default(now())
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("MEMBER")
  @@unique([groupId, userId])
}

model GroupEvent {
  id            String   @id @default(cuid())
  groupId        String
  creatorId      String
  title          String
  description    String?
  startsAt       DateTime
  endsAt         DateTime?
  locationName   String?
  latitude       Float?
  longitude      Float?
  googleMapsUrl  String?
  createdAt      DateTime @default(now())
  group          Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator        User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

model GroupForumThread {
  id          String   @id @default(cuid())
  groupId      String
  authorId     String
  title        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  posts        GroupForumPost[]
}

model GroupForumPost {
  id          String   @id @default(cuid())
  threadId     String
  authorId     String
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  thread       GroupForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model GroupDocument {
  id          String   @id @default(cuid())
  groupId      String
  uploaderId   String
  title        String
  url          String
  createdAt    DateTime @default(now())
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model GroupPhoto {
  id          String   @id @default(cuid())
  groupId      String
  albumId      String?
  uploaderId   String
  caption      String?
  tags         String?
  url          String
  createdAt    DateTime @default(now())
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  album        GroupPhotoAlbum? @relation(fields: [albumId], references: [id], onDelete: SetNull)
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model GroupPhotoAlbum {
  id          String   @id @default(cuid())
  groupId      String
  title        String
  description  String?
  createdAt    DateTime @default(now())
  group        Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  photos       GroupPhoto[]
  @@unique([groupId, title])
}

model UserFollow {
  id           String   @id @default(cuid())
  followerId   String
  followingId  String
  createdAt    DateTime @default(now())
  follower     User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following    User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  @@unique([followerId, followingId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  body        String
  targetUrl   String?
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Alert {
  id          String   @id @default(cuid())
  userId      String
  type        String
  sourceType  String
  sourceId    String
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model AlertSubscription {
  id          String   @id @default(cuid())
  userId      String
  type        String
  sourceType  String
  sourceId    String
  label       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, type, sourceType, sourceId])
  @@index([userId, isActive])
}

model PhotoAlbum {
  id          String   @id @default(cuid())
  userId      String
  title       String
  visibility  String   @default("PUBLIC")
  shareGroupIds String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos      Photo[]
  albumTags   PhotoAlbumTag[]
}

model Photo {
  id          String   @id @default(cuid())
  albumId     String
  url         String
  caption     String?
  tags        String?
  commentsLocked Boolean @default(false)
  visibility  String   @default("PUBLIC")
  createdAt   DateTime @default(now())
  album       PhotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  comments    PhotoComment[]
  photoTags   PhotoTag[]
}

model PhotoComment {
  id         String   @id @default(cuid())
  photoId    String
  authorId   String
  parentCommentId String?
  content    String
  mediaUrlsJson String?
  createdAt  DateTime @default(now())
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  @@index([photoId, parentCommentId, createdAt])
  @@index([photoId, createdAt])
}

model UserMediaTag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  albumTags PhotoAlbumTag[]
  photoTags PhotoTag[]
  @@unique([userId, name])
  @@index([userId, createdAt])
}

model PhotoAlbumTag {
  albumId String
  tagId   String
  album   PhotoAlbum  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  tag     UserMediaTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([albumId, tagId])
  @@index([tagId])
}

model PhotoTag {
  photoId String
  tagId   String
  photo   Photo       @relation(fields: [photoId], references: [id], onDelete: Cascade)
  tag     UserMediaTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([photoId, tagId])
  @@index([tagId])
}

model UserUploadAsset {
  id        String   @id @default(cuid())
  userId    String
  url       String   @unique
  sizeBytes Int
  mimeType  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model UserFeedPreference {
  id             String   @id @default(cuid())
  userId         String   @unique
  mode           String   @default("CHRONOLOGICAL")
  mobileNavSwipeSide String @default("RIGHT")
  allowFriendFamilyStreamPosts Boolean @default(true)
  requireApprovalForFriendFamilyStreamPosts Boolean @default(false)
  notificationDingsEnabled Boolean @default(true)
  alertDingsEnabled Boolean @default(true)
  closeFriendIds String?
  hiddenPostIds  String?
  topicWeights   String?
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MutedUser {
  id            String   @id @default(cuid())
  userId        String
  mutedUserId   String
  createdAt     DateTime @default(now())
  user          User     @relation("MutedByUser", fields: [userId], references: [id], onDelete: Cascade)
  mutedUser     User     @relation("MutedTargetUser", fields: [mutedUserId], references: [id], onDelete: Cascade)
  @@unique([userId, mutedUserId])
}

model UserBlock {
  id            String   @id @default(cuid())
  userId        String
  blockedUserId String
  createdAt     DateTime @default(now())
  user          User     @relation("UserBlocks", fields: [userId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("UserBlockedBy", fields: [blockedUserId], references: [id], onDelete: Cascade)
  @@unique([userId, blockedUserId])
  @@index([userId, createdAt])
}

model MutedTopic {
  id          String   @id @default(cuid())
  userId      String
  topic       String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, topic])
}

model FollowedTopic {
  id          String   @id @default(cuid())
  userId      String
  topic       String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, topic])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TwoFactorConfig {
  id          String   @id @default(cuid())
  userId      String   @unique
  secret      String
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserKeyMaterial {
  id                  String   @id @default(cuid())
  userId              String   @unique
  publicKeyPem        String
  encryptedPrivateKey String
  wrappedDekForSystem String
  wrappedDekForAdmin  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSecurityEvent {
  id         String   @id @default(cuid())
  userId     String?
  eventType  String
  ipAddress  String?
  userAgent  String?
  metadata   String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId, createdAt])
  @@index([eventType, createdAt])
}

model JobListing {
  id            String   @id @default(cuid())
  creatorId     String
  companyName   String
  title         String
  duties        String
  requirements  String?
  salaryMin     Float?
  salaryMax     Float?
  location      String?
  employmentType String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  creator       User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  @@index([status, createdAt])
  @@index([location, createdAt])
}

model AuditorListing {
  id            String   @id @default(cuid())
  userId        String
  displayName   String
  classLevel    String
  location      String?
  country       String?
  state         String?
  city          String?
  travels       Boolean  @default(false)
  lookingForPcs Boolean  @default(false)
  trainedAt     String?
  credentials   String?
  specialtyCourses String?
  bio           String?
  services      String?
  successStories String?
  successStoriesJson String?
  textStream    String?
  proEnabled    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media         AuditorMedia[]
  @@unique([userId])
  @@index([classLevel, createdAt])
  @@index([location, createdAt])
  @@index([country, state, city, createdAt])
  @@index([lookingForPcs, createdAt])
}

model AuditorMedia {
  id              String   @id @default(cuid())
  auditorListingId String
  url             String
  caption         String?
  createdAt       DateTime @default(now())
  auditorListing  AuditorListing @relation(fields: [auditorListingId], references: [id], onDelete: Cascade)
  @@index([auditorListingId, createdAt])
}

model ModeratorActionLog {
  id           String   @id @default(cuid())
  actorUserId  String
  action       String
  targetType   String
  targetId     String
  note         String?
  createdAt    DateTime @default(now())
  actor        User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
}

model AdminPetition {
  id          String   @id @default(cuid())
  requesterId String
  subject     String
  details     String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  requester   User     @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  @@index([status, createdAt])
  @@index([requesterId, createdAt])
}
