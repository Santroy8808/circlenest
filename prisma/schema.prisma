  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  employer            User              @relation("JobListingEmployer", fields: [employerUserId], references: [id], onDelete: Cascade)

  @@index([status, category, createdAt])
  @@index([employerUserId, createdAt])
}

model AuditorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  practiceName    String
  location        String?
  willingToTravel Boolean  @default(false)
  bio             String?
  offerings       String?
  phone           String?
  website         String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([active, createdAt])
}

model BusinessProfile {
  id                      String              @id @default(cuid())
  ownerUserId             String              @unique
  profileKind             BusinessProfileKind @default(BUSINESS)
  slug                    String              @unique
  businessName            String
  contactPersonName       String?
  tagline                 String?
  description             String?
  location                String?
  publicEmail             String?
  phone                   String?
  website                 String?
  logoUrl                 String?
  bannerUrl               String?
  heroImageUrl            String?
  galleryImageUrls        String[]            @default([])
  blogEnabled             Boolean             @default(false)
  publicStorefrontEnabled Boolean             @default(false)
  emailLinkingEnabled     Boolean             @default(false)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  owner                   User                @relation("BusinessProfileOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  inquiries               BusinessInquiry[]
  adCampaigns             AdCampaign[]
  articles                BusinessArticle[]

  @@index([publicStorefrontEnabled, updatedAt])
}

model BusinessInquiry {
  id                String                @id @default(cuid())
  businessProfileId String
  mailThreadId      String?
  senderName        String
  senderEmail       String?
  message           String
  status            BusinessInquiryStatus @default(NEW)
  createdAt         DateTime              @default(now())
  businessProfile   BusinessProfile       @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, status, createdAt])
  @@index([mailThreadId])
}

model BusinessArticle {
  id                String          @id @default(cuid())
  ownerUserId       String
  businessProfileId String
  coverMediaAssetId String?
  slug              String          @unique
  title             String
  summary           String?
  body              String
  published         Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  owner             User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  coverMediaAsset   MediaAsset?     @relation("BusinessArticleCover", fields: [coverMediaAssetId], references: [id], onDelete: SetNull)
  adCampaigns       AdCampaign[]

  @@index([ownerUserId, createdAt])
  @@index([businessProfileId, published, createdAt])
}

model PlatformCostRule {
  id              String              @id @default(cuid())
  key             String              @unique
  subject         PlatformCostSubject
  label           String
  description     String?
  creditCost      Int
  durationDays    Int?
  includedUnits   Int?
  unitLabel       String              @default("package")
  active          Boolean             @default(true)
  sortOrder       Int                 @default(0)
  metadata        Json?
  updatedByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  updatedBy       User?               @relation("PlatformCostRuleUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([subject, active, sortOrder])
  @@index([updatedByUserId, updatedAt])
}

model AdCampaign {
  id                 String                     @id @default(cuid())
  ownerUserId        String
  businessProfileId  String?
  marketListingId    String?
  businessArticleId  String?
  subscriberTargetManuscriptId String?
  imageMediaAssetId  String?
  externalImageUrl   String?
  title              String
  body               String
  destinationUrl     String?
  destinationKind    AdDestinationKind          @default(STOREFRONT)
  placement          AdPlacement                @default(RIGHT_STREAM)
  status             AdCampaignStatus           @default(ACTIVE)
  targetLocation     String?
  totalBudgetCredits Int
  dailyBudgetCredits Int?
  spentCredits       Int                        @default(0)
  startsAt           DateTime?
  endsAt             DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  owner              User                       @relation("AdCampaignOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  businessProfile    BusinessProfile?           @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  marketListing      MarketListing?             @relation(fields: [marketListingId], references: [id], onDelete: SetNull)
  businessArticle    BusinessArticle?           @relation(fields: [businessArticleId], references: [id], onDelete: SetNull)
  subscriberTargetManuscript WriterManuscript?   @relation("AdSubscriberTargetManuscript", fields: [subscriberTargetManuscriptId], references: [id], onDelete: SetNull)
  imageMediaAsset    MediaAsset?                @relation("AdCampaignImage", fields: [imageMediaAssetId], references: [id], onDelete: SetNull)
  deliveryLogs       AdDeliveryLog[]
  targetInterests    AdCampaignInterestTarget[]

  @@index([status, placement, createdAt])
  @@index([ownerUserId, createdAt])
  @@index([businessProfileId, createdAt])
  @@index([marketListingId, createdAt])
  @@index([businessArticleId, createdAt])
  @@index([subscriberTargetManuscriptId, createdAt])
  @@index([imageMediaAssetId])
}

model AdCampaignInterestTarget {
  id         String           @id @default(cuid())
  campaignId String
  category   InterestCategory
  createdAt  DateTime         @default(now())
  campaign   AdCampaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, category])
  @@index([category])
}

model AdCreditLedgerEntry {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  reason     String
  sourceType String?
  sourceId   String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
}

model AdDeliveryLog {
  id           String              @id @default(cuid())
  campaignId   String
  viewerUserId String?
  placement    AdPlacement
  eventType    AdDeliveryEventType
  metadata     Json?
  createdAt    DateTime            @default(now())
  campaign     AdCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  viewer       User?               @relation("AdDeliveryViewer", fields: [viewerUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, eventType, createdAt])
  @@index([viewerUserId, createdAt])
  @@index([placement, createdAt])
}

model FundraiserCampaign {
  id              String                   @id @default(cuid())
  slug            String                   @unique
  creatorUserId   String
  title           String
  summary         String?
  description     String
  category        FundraiserCategory
  goalAmountCents Int?
  currency        String                   @default("USD")
  status          FundraiserStatus         @default(ACTIVE)
  endsAt          DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  creator         User                     @relation("FundraiserCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  contributions   FundContributionIntent[]
  ledgerEntries   FundLedgerEntry[]

  @@index([status, category, createdAt])
  @@index([creatorUserId, createdAt])
}

model FundContributionIntent {
  id                 String                 @id @default(cuid())
  campaignId         String
  contributorUserId  String?
  contributorName    String?
  amountCents        Int
  currency           String                 @default("USD")
  status             FundContributionStatus @default(PLEDGED)
  processorProvider  String?
  processorReference String?
  note               String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  campaign           FundraiserCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contributor        User?                  @relation("FundContributionContributor", fields: [contributorUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, status, createdAt])
  @@index([contributorUserId, createdAt])
}

model FundLedgerEntry {
  id          String              @id @default(cuid())
  campaignId  String
  entryType   FundLedgerEntryType
  amountCents Int
  currency    String              @default("USD")
  sourceType  String?
  sourceId    String?
  note        String?
  createdAt   DateTime            @default(now())
  campaign    FundraiserCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([sourceType, sourceId])
}

model WriterManuscript {
  id                  String               @id @default(cuid())
  slug                String               @unique
  authorUserId        String
  title               String
  genre               String?
  summary             String?
  visibility          ManuscriptVisibility @default(MEMBERS)
  publishToStorefront Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  author              User                 @relation("WriterManuscriptAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  chapters            WriterChapter[]
  subscriptions       WriterManuscriptSubscription[]
  subscriberTargetedAds AdCampaign[]       @relation("AdSubscriberTargetManuscript")

  @@index([authorUserId, updatedAt])
  @@index([authorUserId, publishToStorefront, updatedAt])
  @@index([visibility, updatedAt])
}

model WriterManuscriptSubscription {
  id           String           @id @default(cuid())
  manuscriptId String
  userId       String
  notify       Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  manuscript   WriterManuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([manuscriptId, userId])
  @@index([userId, updatedAt])
  @@index([manuscriptId, notify])
}

model WriterChapter {
  id           String           @id @default(cuid())
  manuscriptId String
  title        String
  bodyText     String           @default("")
  bodyHtml     String?
  wordCount    Int              @default(0)
  sortOrder    Int              @default(0)
  publishedAt  DateTime?
  autosavedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  manuscript   WriterManuscript @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)

  @@index([manuscriptId, sortOrder])
  @@index([publishedAt, updatedAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Alert {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model AuthSecurityEvent {
  id         String                @id @default(cuid())
  userId     String?
  type       AuthSecurityEventType
  identifier String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime              @default(now())
  user       User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([identifier, createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([email, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TwoFactorConfig {
  id            String    @id @default(cuid())
  userId        String    @unique
  enabled       Boolean   @default(false)
  method        String?
  secretHash    String?
  recoveryCodes Json?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackTicket {
  id             String                 @id @default(cuid())
  publicId       String                 @unique
  reporterUserId String?
  reporterEmail  String?
  pageUrl        String?
  title          String
  description    String
  severity       FeedbackTicketSeverity @default(normal)
  status         FeedbackTicketStatus   @default(OPEN)
  userAgent      String?
  diagnostics    Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  reporter       User?                  @relation("FeedbackReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  events         FeedbackTicketEvent[]

  @@index([status, createdAt])
  @@index([reporterUserId, createdAt])
}

model FeedbackTicketEvent {
  id        String         @id @default(cuid())
  ticketId  String
  actorId   String?
  action    String
  metadata  Json?
  createdAt DateTime       @default(now())
  ticket    FeedbackTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model MembershipPolicyOverride {
  id              String    @id @default(cuid())
  userId          String
  featureKey      String
  allowed         Boolean
  reason          String?
  expiresAt       DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation("MembershipOverrideSubject", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?     @relation("MembershipOverrideCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, featureKey])
  @@index([featureKey, allowed])
  @@index([userId, expiresAt])
}
