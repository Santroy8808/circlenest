generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipTier {
  FREE
  CONTRIBUTOR
  PROFESSIONAL
  AUDITOR
}

enum UserRole {
  MEMBER
  ADMIN
}

enum LogLevel {
  debug
  info
  warn
  error
}

enum AuditSeverity {
  info
  warning
  critical
}

enum ModuleHealthStatus {
  healthy
  degraded
  offline
  unknown
}

enum MediaVisibility {
  PRIVATE
  MEMBERS
  PUBLIC
}

enum MediaCollectionType {
  ALBUM
  TAG
  SYSTEM_DATE
}

enum FeedVisibility {
  MEMBERS
  FRIENDS
  PRIVATE
}

enum FeedReactionType {
  LIKE
  LOVE
  CARE
  HAHA
  WOW
  SAD
  ANGRY
}

enum SocialRelationshipType {
  FRIEND
  FAMILY
  CONTACT
  FOLLOW
  BLOCK
  MUTE
}

enum ChatThreadType {
  DIRECT
  GROUP
}

enum ChatAttachmentKind {
  IMAGE
  FILE
}

enum MailDeliveryKind {
  DIRECT
  MASS_INTERNAL
}

enum MailRecipientType {
  TO
  CC
  BCC
}

enum MailAttachmentKind {
  IMAGE
  FILE
}

enum GroupVisibility {
  PUBLIC
  PRIVATE
}

enum GroupJoinPolicy {
  OPEN
  APPROVAL
}

enum GroupMemberRole {
  MEMBER
  MODERATOR
  OWNER
}

enum GroupJoinRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

enum GroupForumReactionType {
  LIKE
  LOVE
  CARE
  HAHA
  WOW
  SAD
  ANGRY
}

enum GroupAssetKind {
  PHOTO
  DOCUMENT
}

enum EventStatus {
  PUBLISHED
  CANCELED
  ENDED
}

enum EventModeratorRole {
  OWNER
  MODERATOR
}

enum EventInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

enum EventRsvpStatus {
  GOING
  MAYBE
  DECLINED
}

enum MarketListingCategory {
  BOOKS_MATERIALS
  COURSE_SUPPLIES
  AUDITING_SUPPLIES
  E_METERS
  FURNITURE_EQUIPMENT
  SERVICES
  BUSINESS_SERVICES
  EVENTS_SUPPLIES
  OTHER
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  ARCHIVED
}

enum JobCategory {
  ADMINISTRATION
  TECHNICAL
  SALES
  DELIVERY
  AUDITING
  TRAINING
  CREATIVE
  PROFESSIONAL_SERVICES
  OTHER
}

enum JobEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  VOLUNTEER
}

enum JobListingStatus {
  ACTIVE
  FILLED
  ARCHIVED
}

enum BusinessInquiryStatus {
  NEW
  READ
  ARCHIVED
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
}

enum AdPlacement {
  RIGHT_STREAM
  BUSINESS_SPOTLIGHT
  RESERVED_STREAM
}

enum AdDeliveryEventType {
  IMPRESSION
  CLICK
}

enum FundraiserCategory {
  COMMUNITY_PROJECT
  EVENT_SUPPORT
  MATERIALS_SUPPLIES
  EMERGENCY_SUPPORT
  OTHER
}

enum FundraiserStatus {
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
}

enum FundContributionStatus {
  PLEDGED
  PROCESSOR_PENDING
  PROCESSOR_CONFIRMED
  CANCELED
  REFUNDED
}

enum FundLedgerEntryType {
  PROCESSOR_CONFIRMED_CONTRIBUTION
  PROCESSOR_REFUND
  WITHDRAWAL_BATCH_CAPTURE
}

enum AuthSecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  SIGNUP_CREATED
  EMAIL_VERIFICATION_REQUESTED
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  SESSION_REVOKED
  TWO_FACTOR_READY
}

enum FeedbackTicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum FeedbackTicketSeverity {
  low
  normal
  high
  urgent
}

enum ProfileVisibility {
  PRIVATE
  MEMBERS
  PUBLIC
}

enum ScientologyVisibility {
  PRIVATE
  MEMBERS
}

enum ScientologyClassification {
  PUBLIC
  PRECLEAR
  CLEAR
  OT
  AUDITOR
  STAFF
  SEA_ORG
  OTHER
}

model User {
  id                       String                   @id @default(cuid())
  email                    String                   @unique
  username                 String                   @unique
  passwordHash             String?
  role                     UserRole                 @default(MEMBER)
  emailVerified            DateTime?
  deactivatedAt            DateTime?
  sessionVersion           Int                      @default(1)
  failedLoginCount         Int                      @default(0)
  lastLoginAt              DateTime?
  lastPasswordChangedAt    DateTime?
  sessionsRevokedAt        DateTime?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  profile                  Profile?
  scientologyProfile       ScientologyProfile?
  membership               Membership?
  mediaAssets              MediaAsset[]
  mediaCollections         MediaCollection[]
  feedPosts                FeedPost[]                @relation("FeedPostAuthor")
  feedComments             FeedComment[]             @relation("FeedCommentAuthor")
  feedPostReactions        FeedPostReaction[]
  feedCommentReactions     FeedCommentReaction[]
  socialRelationshipsFrom  SocialRelationship[]      @relation("SocialRelationshipFrom")
  socialRelationshipsTo    SocialRelationship[]      @relation("SocialRelationshipTo")
  createdChatThreads       ChatThread[]              @relation("ChatThreadCreator")
  chatParticipants         ChatParticipant[]
  chatMessages             ChatMessage[]             @relation("ChatMessageSender")
  createdMailThreads       MailThread[]              @relation("MailThreadCreator")
  sentMailMessages         MailMessage[]             @relation("MailMessageSender")
  mailRecipients           MailRecipient[]
  ownedMailContacts        MailContact[]             @relation("MailContactOwner")
  contactMailEntries       MailContact[]             @relation("MailContactUser")
  mailPreference           MailPreference?
  mailSenderOptOuts        MailSenderOptOut[]        @relation("MailOptOutOwner")
  mailSenderBlocks         MailSenderOptOut[]        @relation("MailOptOutSender")
  createdGroups            Group[]                    @relation("GroupCreator")
  groupMemberships         GroupMember[]
  groupJoinRequests        GroupJoinRequest[]         @relation("GroupJoinRequester")
  reviewedGroupJoinRequests GroupJoinRequest[]        @relation("GroupJoinReviewer")
  groupPins                GroupUserPin[]
  groupForumThreads        GroupForumThread[]         @relation("GroupForumThreadAuthor")
  endedGroupForumThreads   GroupForumThread[]         @relation("GroupForumThreadEnder")
  deletedGroupForumThreads GroupForumThread[]         @relation("GroupForumThreadDeleter")
  groupForumPosts          GroupForumPost[]           @relation("GroupForumPostAuthor")
  groupForumThreadReactions GroupForumThreadReaction[]
  groupForumPostReactions  GroupForumPostReaction[]
  uploadedGroupAssets      GroupAsset[]               @relation("GroupAssetUploader")
  groupAssetComments       GroupAssetComment[]         @relation("GroupAssetCommentAuthor")
  createdEvents            Event[]                    @relation("EventCreator")
  eventModerations         EventModerator[]
  eventInvitationsSent     EventInvitation[]          @relation("EventInvitationSender")
  eventInvitationsReceived EventInvitation[]          @relation("EventInvitationInvitee")
  eventRsvps               EventRsvp[]
  marketListings           MarketListing[]           @relation("MarketListingSeller")
  jobListings              JobListing[]              @relation("JobListingEmployer")
  auditorProfile           AuditorProfile?
  businessProfile          BusinessProfile?          @relation("BusinessProfileOwner")
  adCampaigns              AdCampaign[]              @relation("AdCampaignOwner")
  adCreditLedgerEntries    AdCreditLedgerEntry[]
  adDeliveryLogs           AdDeliveryLog[]           @relation("AdDeliveryViewer")
  fundraiserCampaigns      FundraiserCampaign[]      @relation("FundraiserCreator")
  fundContributionIntents  FundContributionIntent[]  @relation("FundContributionContributor")
  notifications            Notification[]
  alerts                   Alert[]
  diagnostics              DiagnosticLog[]
  auditLogs                AuditLog[]               @relation("AuditActor")
  adminActions             AdminAction[]            @relation("AdminActionActor")
  authSecurityEvents       AuthSecurityEvent[]
  emailVerificationTokens  EmailVerificationToken[]
  passwordResetTokens      PasswordResetToken[]
  twoFactorConfig          TwoFactorConfig?
  feedbackTickets          FeedbackTicket[]         @relation("FeedbackReporter")
  membershipOverrides      MembershipPolicyOverride[] @relation("MembershipOverrideSubject")
  createdMembershipOverrides MembershipPolicyOverride[] @relation("MembershipOverrideCreator")
}

model Profile {
  id          String            @id @default(cuid())
  userId      String            @unique
  displayName String?
  tagline     String?
  bio         String?
  avatarUrl   String?
  bannerUrl   String?
  location    String?
  visibility  ProfileVisibility @default(MEMBERS)
  theme        Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScientologyProfile {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  classification        ScientologyClassification @default(PUBLIC)
  orgName               String?
  lastServiceName       String?
  lastServiceAt         DateTime?
  trainingLevel         String?
  processingStatus      String?
  goodStandingAttested  Boolean                   @default(false)
  goodStandingUpdatedAt DateTime?
  educationNotes        String?
  visibility            ScientologyVisibility     @default(PRIVATE)
  adTargetingAllowed    Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Membership {
  id                 String         @id @default(cuid())
  userId             String         @unique
  tier               MembershipTier @default(FREE)
  inviteEligibleAt   DateTime?
  storageLimitBytes  BigInt         @default(104857600)
  platformCredits    Int            @default(0)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DiagnosticLog {
  id         String   @id @default(cuid())
  level      LogLevel
  module     String
  message    String
  context    Json?
  requestId  String?
  userId     String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([module, createdAt])
  @@index([level, createdAt])
}

model AuditLog {
  id          String        @id @default(cuid())
  actorUserId String?
  module      String
  action      String
  targetType  String?
  targetId    String?
  severity    AuditSeverity @default(info)
  metadata    Json?
  createdAt   DateTime      @default(now())
  actor       User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([module, action, createdAt])
  @@index([actorUserId, createdAt])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModuleHealthCheck {
  id          String             @id @default(cuid())
  module      String             @unique
  status      ModuleHealthStatus @default(unknown)
  message     String?
  checkedAt   DateTime           @default(now())
  metadata    Json?
}

model AdminAction {
  id          String   @id @default(cuid())
  actorUserId String?
  actionKey   String
  module      String
  status      String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AdminActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actionKey, createdAt])
  @@index([actorUserId, createdAt])
}

model MediaAsset {
  id           String          @id @default(cuid())
  ownerUserId  String
  storageKey   String          @unique
  publicUrl    String?
  mimeType     String
  sizeBytes    BigInt
  originalName String?
  visibility   MediaVisibility @default(PRIVATE)
  metadata     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  owner        User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  collections  MediaCollectionAsset[]
  feedPosts    FeedPost[]
  feedComments FeedComment[]
  chatAttachments ChatAttachment[]
  mailAttachments MailAttachment[]
  groupForumPosts GroupForumPost[]
  groupAssets   GroupAsset[]
  marketListingPhotos MarketListingPhoto[]

  @@index([ownerUserId, createdAt])
}

model MediaCollection {
  id          String              @id @default(cuid())
  ownerUserId String
  type        MediaCollectionType
  name        String
  slug        String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  owner       User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  assets      MediaCollectionAsset[]

  @@unique([ownerUserId, type, slug])
  @@index([ownerUserId, type, name])
}

model MediaCollectionAsset {
  id           String          @id @default(cuid())
  collectionId String
  mediaAssetId String
  assignedAt   DateTime        @default(now())
  collection   MediaCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset      @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([collectionId, mediaAssetId])
  @@index([mediaAssetId, assignedAt])
}

model FeedPost {
  id           String             @id @default(cuid())
  authorUserId String
  body         String
  visibility   FeedVisibility     @default(MEMBERS)
  mediaAssetId String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  author       User               @relation("FeedPostAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset?        @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  comments     FeedComment[]
  reactions    FeedPostReaction[]

  @@index([visibility, createdAt])
  @@index([authorUserId, createdAt])
}

model FeedComment {
  id              String                @id @default(cuid())
  postId          String
  authorUserId    String
  parentCommentId String?
  body            String
  mediaAssetId    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?
  post            FeedPost              @relation(fields: [postId], references: [id], onDelete: Cascade)
  author          User                  @relation("FeedCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  parent          FeedComment?          @relation("FeedCommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         FeedComment[]         @relation("FeedCommentReplies")
  mediaAsset      MediaAsset?           @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  reactions       FeedCommentReaction[]

  @@index([postId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([parentCommentId, createdAt])
}

model FeedPostReaction {
  id        String           @id @default(cuid())
  postId    String
  userId    String
  type      FeedReactionType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  post      FeedPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, type])
}

model FeedCommentReaction {
  id        String           @id @default(cuid())
  commentId String
  userId    String
  type      FeedReactionType
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  comment   FeedComment      @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId, type])
}

model SocialRelationship {
  id           String                 @id @default(cuid())
  fromUserId   String
  toUserId     String
  type         SocialRelationshipType
  note         String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  fromUser     User                   @relation("SocialRelationshipFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User                   @relation("SocialRelationshipTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId, type])
  @@index([fromUserId, type, createdAt])
  @@index([toUserId, type, createdAt])
}

model ChatThread {
  id              String             @id @default(cuid())
  type            ChatThreadType
  title           String?
  createdByUserId String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  lastMessageAt   DateTime?
  createdBy       User?              @relation("ChatThreadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  participants    ChatParticipant[]
  messages        ChatMessage[]

  @@index([type, lastMessageAt])
  @@index([createdByUserId, createdAt])
}

model ChatParticipant {
  id          String     @id @default(cuid())
  threadId    String
  userId      String
  nickname    String?
  mutedAt     DateTime?
  archivedAt  DateTime?
  lastReadAt  DateTime?
  createdAt   DateTime   @default(now())
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, archivedAt, createdAt])
}

model ChatMessage {
  id           String           @id @default(cuid())
  threadId     String
  senderUserId String
  body         String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  thread       ChatThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender       User             @relation("ChatMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  attachments  ChatAttachment[]

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt])
}

model ChatAttachment {
  id           String             @id @default(cuid())
  messageId    String
  mediaAssetId String?
  kind         ChatAttachmentKind
  fileName     String
  mimeType     String
  sizeBytes    BigInt
  storageKey   String?
  publicUrl    String?
  createdAt    DateTime           @default(now())
  message      ChatMessage        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset?        @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@index([mediaAssetId])
}

model MailThread {
  id              String           @id @default(cuid())
  subject         String
  deliveryKind    MailDeliveryKind @default(DIRECT)
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  lastMessageAt   DateTime?
  createdBy       User?            @relation("MailThreadCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  messages        MailMessage[]

  @@index([deliveryKind, lastMessageAt])
  @@index([createdByUserId, createdAt])
}

model MailMessage {
  id           String           @id @default(cuid())
  threadId     String
  senderUserId String
  subject      String
  bodyText     String
  bodyHtml     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  thread       MailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender       User             @relation("MailMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)
  recipients   MailRecipient[]
  attachments  MailAttachment[]

  @@index([threadId, createdAt])
  @@index([senderUserId, createdAt])
}

model MailRecipient {
  id         String            @id @default(cuid())
  messageId  String
  userId     String
  type       MailRecipientType @default(TO)
  readAt     DateTime?
  archivedAt DateTime?
  deletedAt  DateTime?
  createdAt  DateTime          @default(now())
  message    MailMessage       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, type])
  @@index([userId, readAt, createdAt])
  @@index([userId, archivedAt, createdAt])
}

model MailAttachment {
  id           String             @id @default(cuid())
  messageId    String
  mediaAssetId String?
  kind         MailAttachmentKind
  fileName     String
  mimeType     String
  sizeBytes    BigInt
  storageKey   String?
  publicUrl    String?
  createdAt    DateTime           @default(now())
  message      MailMessage        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mediaAsset   MediaAsset?        @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@index([mediaAssetId])
}

model MailContact {
  id            String   @id @default(cuid())
  ownerUserId   String
  contactUserId String
  displayName   String?
  notes         String?
  source        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  owner         User     @relation("MailContactOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  contactUser   User     @relation("MailContactUser", fields: [contactUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, contactUserId])
  @@index([ownerUserId, createdAt])
}

model MailPreference {
  id            String   @id @default(cuid())
  userId        String   @unique
  allowMassMail Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MailSenderOptOut {
  id           String   @id @default(cuid())
  ownerUserId  String
  senderUserId String
  reason       String?
  createdAt    DateTime @default(now())
  owner        User     @relation("MailOptOutOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  sender       User     @relation("MailOptOutSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, senderUserId])
  @@index([senderUserId, createdAt])
}

model MailPolicyConfig {
  id                              String   @id @default("default")
  contributorMassRecipientCap     Int      @default(5)
  professionalMassRecipientCap    Int      @default(25)
  auditorMassRecipientCap         Int      @default(5)
  adminMassRecipientCap           Int      @default(100)
  massMailCostPerRecipientCredits Int      @default(0)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt
}

model Group {
  id                String          @id @default(cuid())
  slug              String          @unique
  name              String
  tagline           String?
  description       String?
  avatarUrl         String?
  bannerUrl         String?
  visibility        GroupVisibility @default(PUBLIC)
  joinPolicy        GroupJoinPolicy @default(OPEN)
  createdByUserId   String?
  storageLimitBytes BigInt          @default(41943040)
  archivedAt        DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         User?           @relation("GroupCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  members           GroupMember[]
  joinRequests      GroupJoinRequest[]
  pins              GroupUserPin[]
  forumThreads      GroupForumThread[]
  assets            GroupAsset[]

  @@index([visibility, archivedAt, createdAt])
  @@index([createdByUserId, createdAt])
}

model GroupMember {
  id         String          @id @default(cuid())
  groupId    String
  userId     String
  role       GroupMemberRole @default(MEMBER)
  isProvider Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  group      Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([userId, role, createdAt])
  @@index([groupId, role])
}

model GroupJoinRequest {
  id               String                 @id @default(cuid())
  groupId          String
  requesterUserId  String
  status           GroupJoinRequestStatus @default(PENDING)
  note             String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  group            Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  requester        User                   @relation("GroupJoinRequester", fields: [requesterUserId], references: [id], onDelete: Cascade)
  reviewedBy       User?                  @relation("GroupJoinReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([requesterUserId, createdAt])
  @@index([groupId, status, createdAt])
}

model GroupUserPin {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  sortOrder Int      @default(0)
  pinnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId, sortOrder, pinnedAt])
}

model GroupForumThread {
  id                String                      @id @default(cuid())
  groupId           String
  authorUserId      String
  title             String
  body              String
  allowPhotoReplies Boolean                     @default(false)
  pinnedAt          DateTime?
  sortOrder         Int                         @default(0)
  endedAt           DateTime?
  endedByUserId     String?
  deletedAt         DateTime?
  deletedByUserId   String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt
  group             Group                       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author            User                        @relation("GroupForumThreadAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  endedBy           User?                       @relation("GroupForumThreadEnder", fields: [endedByUserId], references: [id], onDelete: SetNull)
  deletedBy         User?                       @relation("GroupForumThreadDeleter", fields: [deletedByUserId], references: [id], onDelete: SetNull)
  posts             GroupForumPost[]
  reactions         GroupForumThreadReaction[]

  @@index([groupId, deletedAt, pinnedAt, updatedAt])
  @@index([authorUserId, createdAt])
}

model GroupForumPost {
  id           String                   @id @default(cuid())
  threadId     String
  authorUserId String
  parentPostId String?
  body         String
  mediaAssetId String?
  deletedAt    DateTime?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  thread       GroupForumThread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author       User                     @relation("GroupForumPostAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  parent       GroupForumPost?          @relation("GroupForumPostReplies", fields: [parentPostId], references: [id], onDelete: SetNull)
  replies      GroupForumPost[]         @relation("GroupForumPostReplies")
  mediaAsset   MediaAsset?              @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)
  reactions    GroupForumPostReaction[]

  @@index([threadId, createdAt])
  @@index([authorUserId, createdAt])
  @@index([parentPostId, createdAt])
}

model GroupForumThreadReaction {
  id        String                 @id @default(cuid())
  threadId  String
  userId    String
  type      GroupForumReactionType
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  thread    GroupForumThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([threadId, type])
}

model GroupForumPostReaction {
  id        String                 @id @default(cuid())
  postId    String
  userId    String
  type      GroupForumReactionType
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  post      GroupForumPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId, type])
}

model GroupAsset {
  id             String             @id @default(cuid())
  groupId        String
  mediaAssetId   String
  uploaderUserId String
  kind           GroupAssetKind
  headline       String?
  description    String?
  deletedAt      DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  group          Group              @relation(fields: [groupId], references: [id], onDelete: Cascade)
  mediaAsset     MediaAsset         @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  uploader       User               @relation("GroupAssetUploader", fields: [uploaderUserId], references: [id], onDelete: Cascade)
  comments       GroupAssetComment[]

  @@index([groupId, kind, createdAt])
  @@index([uploaderUserId, createdAt])
}

model GroupAssetComment {
  id            String     @id @default(cuid())
  groupAssetId  String
  authorUserId  String
  body          String
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  asset         GroupAsset @relation(fields: [groupAssetId], references: [id], onDelete: Cascade)
  author        User       @relation("GroupAssetCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([groupAssetId, createdAt])
  @@index([authorUserId, createdAt])
}

model Event {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  summary         String?
  description     String?
  locationName    String?
  address         String?
  startsAt        DateTime
  endsAt          DateTime?
  status          EventStatus       @default(PUBLISHED)
  createdByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       User?             @relation("EventCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  moderators      EventModerator[]
  invitations     EventInvitation[]
  rsvps           EventRsvp[]

  @@index([status, startsAt])
  @@index([createdByUserId, startsAt])
}

model EventModerator {
  id        String             @id @default(cuid())
  eventId   String
  userId    String
  role      EventModeratorRole @default(MODERATOR)
  createdAt DateTime           @default(now())
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, role, createdAt])
}

model EventInvitation {
  id              String                @id @default(cuid())
  eventId         String
  inviteeUserId   String
  invitedByUserId String?
  status          EventInvitationStatus @default(PENDING)
  note            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  event           Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitee         User                  @relation("EventInvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  invitedBy       User?                 @relation("EventInvitationSender", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([eventId, inviteeUserId])
  @@index([inviteeUserId, status, createdAt])
  @@index([eventId, status, createdAt])
}

model EventRsvp {
  id        String          @id @default(cuid())
  eventId   String
  userId    String
  status    EventRsvpStatus
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  event     Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, status, createdAt])
  @@index([eventId, status])
}

model MarketListing {
  id           String                @id @default(cuid())
  slug         String                @unique
  sellerUserId String
  title        String
  description  String
  category     MarketListingCategory
  priceCents   Int?
  currency     String                @default("USD")
  status       MarketListingStatus   @default(ACTIVE)
  expiresAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  seller       User                  @relation("MarketListingSeller", fields: [sellerUserId], references: [id], onDelete: Cascade)
  photos       MarketListingPhoto[]

  @@index([status, category, createdAt])
  @@index([sellerUserId, createdAt])
  @@index([expiresAt])
}

model MarketListingPhoto {
  id              String        @id @default(cuid())
  listingId       String
  mediaAssetId    String
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  listing         MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  mediaAsset      MediaAsset    @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([listingId, mediaAssetId])
  @@index([mediaAssetId, createdAt])
  @@index([listingId, sortOrder])
}

model JobListing {
  id                  String             @id @default(cuid())
  slug                String             @unique
  employerUserId      String
  title               String
  companyName         String?
  summary             String?
  description         String
  category            JobCategory
  employmentType      JobEmploymentType
  location            String?
  remote              Boolean            @default(false)
  compensation        String?
  contactEmail        String?
  contactInstructions String?
  status              JobListingStatus   @default(ACTIVE)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  employer            User               @relation("JobListingEmployer", fields: [employerUserId], references: [id], onDelete: Cascade)

  @@index([status, category, createdAt])
  @@index([employerUserId, createdAt])
}

model AuditorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  practiceName    String
  location        String?
  willingToTravel Boolean  @default(false)
  bio             String?
  offerings       String?
  phone           String?
  website         String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([active, createdAt])
}

model BusinessProfile {
  id                      String            @id @default(cuid())
  ownerUserId             String            @unique
  slug                    String            @unique
  businessName            String
  tagline                 String?
  description             String?
  location                String?
  publicEmail             String?
  phone                   String?
  website                 String?
  publicStorefrontEnabled Boolean           @default(false)
  emailLinkingEnabled     Boolean           @default(false)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  owner                   User              @relation("BusinessProfileOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  inquiries               BusinessInquiry[]
  adCampaigns             AdCampaign[]

  @@index([publicStorefrontEnabled, updatedAt])
}

model BusinessInquiry {
  id                String                @id @default(cuid())
  businessProfileId String
  senderName        String
  senderEmail       String?
  message           String
  status            BusinessInquiryStatus @default(NEW)
  createdAt         DateTime              @default(now())
  businessProfile   BusinessProfile       @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, status, createdAt])
}

model AdCampaign {
  id                   String                     @id @default(cuid())
  ownerUserId          String
  businessProfileId    String?
  title                String
  body                 String
  destinationUrl       String?
  placement            AdPlacement                @default(RIGHT_STREAM)
  status               AdCampaignStatus           @default(ACTIVE)
  targetLocation       String?
  targetClassification ScientologyClassification?
  totalBudgetCredits   Int
  dailyBudgetCredits   Int?
  spentCredits         Int                        @default(0)
  startsAt             DateTime?
  endsAt               DateTime?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  owner                User                       @relation("AdCampaignOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  businessProfile      BusinessProfile?           @relation(fields: [businessProfileId], references: [id], onDelete: SetNull)
  deliveryLogs         AdDeliveryLog[]

  @@index([status, placement, createdAt])
  @@index([ownerUserId, createdAt])
  @@index([businessProfileId, createdAt])
}

model AdCreditLedgerEntry {
  id          String   @id @default(cuid())
  userId      String
  amount      Int
  reason      String
  sourceType  String?
  sourceId    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sourceType, sourceId])
}

model AdDeliveryLog {
  id           String              @id @default(cuid())
  campaignId   String
  viewerUserId String?
  placement    AdPlacement
  eventType    AdDeliveryEventType
  metadata     Json?
  createdAt    DateTime            @default(now())
  campaign     AdCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  viewer       User?               @relation("AdDeliveryViewer", fields: [viewerUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, eventType, createdAt])
  @@index([viewerUserId, createdAt])
  @@index([placement, createdAt])
}

model FundraiserCampaign {
  id             String                     @id @default(cuid())
  slug           String                     @unique
  creatorUserId  String
  title          String
  summary        String?
  description    String
  category       FundraiserCategory
  goalAmountCents Int?
  currency       String                     @default("USD")
  status         FundraiserStatus           @default(ACTIVE)
  endsAt         DateTime?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  creator        User                       @relation("FundraiserCreator", fields: [creatorUserId], references: [id], onDelete: Cascade)
  contributions  FundContributionIntent[]
  ledgerEntries  FundLedgerEntry[]

  @@index([status, category, createdAt])
  @@index([creatorUserId, createdAt])
}

model FundContributionIntent {
  id                String                 @id @default(cuid())
  campaignId        String
  contributorUserId String?
  contributorName   String?
  amountCents       Int
  currency          String                 @default("USD")
  status            FundContributionStatus @default(PLEDGED)
  processorProvider String?
  processorReference String?
  note              String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  campaign          FundraiserCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contributor       User?                  @relation("FundContributionContributor", fields: [contributorUserId], references: [id], onDelete: SetNull)

  @@index([campaignId, status, createdAt])
  @@index([contributorUserId, createdAt])
}

model FundLedgerEntry {
  id          String              @id @default(cuid())
  campaignId  String
  entryType   FundLedgerEntryType
  amountCents Int
  currency    String              @default("USD")
  sourceType  String?
  sourceId    String?
  note        String?
  createdAt   DateTime            @default(now())
  campaign    FundraiserCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, createdAt])
  @@index([sourceType, sourceId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Alert {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model AuthSecurityEvent {
  id          String                @id @default(cuid())
  userId      String?
  type        AuthSecurityEventType
  identifier  String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime              @default(now())
  user        User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type, createdAt])
  @@index([userId, createdAt])
  @@index([identifier, createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([email, expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model TwoFactorConfig {
  id            String    @id @default(cuid())
  userId        String    @unique
  enabled       Boolean   @default(false)
  method        String?
  secretHash    String?
  recoveryCodes Json?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FeedbackTicket {
  id             String                 @id @default(cuid())
  publicId       String                 @unique
  reporterUserId String?
  reporterEmail  String?
  pageUrl        String?
  title          String
  description    String
  severity       FeedbackTicketSeverity @default(normal)
  status         FeedbackTicketStatus   @default(OPEN)
  userAgent      String?
  diagnostics    Json?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  reporter       User?                  @relation("FeedbackReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  events         FeedbackTicketEvent[]

  @@index([status, createdAt])
  @@index([reporterUserId, createdAt])
}

model FeedbackTicketEvent {
  id        String   @id @default(cuid())
  ticketId  String
  actorId   String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())
  ticket    FeedbackTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model MembershipPolicyOverride {
  id              String    @id @default(cuid())
  userId          String
  featureKey      String
  allowed         Boolean
  reason          String?
  expiresAt       DateTime?
  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation("MembershipOverrideSubject", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?     @relation("MembershipOverrideCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, featureKey])
  @@index([featureKey, allowed])
  @@index([userId, expiresAt])
}
