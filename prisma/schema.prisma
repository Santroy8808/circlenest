  reporter           User     @relation("ContentReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  assignedModerator  User?    @relation("ContentReportsAssigned", fields: [assignedModeratorId], references: [id], onDelete: SetNull)
  reviewedBy         User?    @relation("ContentReportsReviewed", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([reporterId, targetType, targetId, createdAt])
  @@index([assignedModeratorId, status, createdAt])
}

model PlatformFeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("PlatformFeatureFlagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([enabled, updatedAt])
}

model PlatformCategory {
  id          String   @id @default(cuid())
  area        String
  name        String
  slug        String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   User?    @relation("PlatformCategoryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([area, slug])
  @@index([area, isActive, sortOrder])
}

model PlatformAnnouncement {
  id              String   @id @default(cuid())
  actorUserId     String
  headline        String
  body            String
  targetUrl       String?
  audienceType    String   @default("GLOBAL")
  audienceValueJson String?
  deliveryModesJson String?
  status          String   @default("DRAFT")
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  actor           User     @relation("PlatformAnnouncementActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([status, publishedAt])
  @@index([audienceType, createdAt])
}

model AdminSupportNote {
  id          String   @id @default(cuid())
  authorUserId String
  targetType  String
  targetId    String
  body        String
  createdAt   DateTime @default(now())
  author      User     @relation("AdminSupportNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, createdAt])
  @@index([authorUserId, createdAt])
}

model WebhookReplayRequest {
  id            String   @id @default(cuid())
  requestedById String
  provider      String
  eventId       String
  status        String   @default("PENDING")
  payloadSummary String?
  resultSummary  String?
  requestedAt   DateTime @default(now())
  replayedAt    DateTime?
  requestedBy   User     @relation("WebhookReplayRequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)

  @@index([provider, eventId])
  @@index([status, requestedAt])
}

model PaymentProcessorConfig {
  id                         String   @id @default(cuid())
  provider                   String
  area                       String
  mode                       String   @default("SANDBOX")
  displayName                String
  publicKeyLabel             String?
  publicKeyFingerprint       String?
  secretEnvVarName           String?
  webhookSecretEnvVarName    String?
  secretConfigured           Boolean  @default(false)
  webhookSecretConfigured    Boolean  @default(false)
  enabledFlowsJson           String?
  platformFeeBps             Int      @default(0)
  withdrawalBatchScheduleJson String?
  processorAccountStatus     String?
  webhookHealthStatus        String   @default("UNKNOWN")
  metadataJson               String?
  isEnabled                  Boolean  @default(false)
  updatedById                String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
  updatedBy                  User?    @relation("PaymentProcessorConfigUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  webhookEvents              PaymentProcessorWebhookEvent[]

  @@unique([provider, area, mode])
  @@index([area, isEnabled, mode])
  @@index([provider, webhookHealthStatus])
}

model PaymentProcessorWebhookEvent {
  id                  String   @id @default(cuid())
  processorConfigId   String
  provider            String
  eventId             String
  eventType           String
  status              String   @default("RECEIVED")
  receivedAt          DateTime @default(now())
  processedAt         DateTime?
  lastError           String?
  retryCount          Int      @default(0)
  reviewedById        String?
  metadataJson        String?
  processorConfig     PaymentProcessorConfig @relation(fields: [processorConfigId], references: [id], onDelete: Cascade)
  reviewedBy          User?    @relation("PaymentProcessorWebhookEventReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([processorConfigId, receivedAt])
  @@index([status, receivedAt])
  @@index([eventType, receivedAt])
}

model DataPrivacyRequest {
  id            String   @id @default(cuid())
  requesterId   String?
  requesterEmail String?
  requestType   String
  status        String   @default("OPEN")
  notes         String?
  handledById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  handledBy     User?    @relation("DataPrivacyRequestHandledBy", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([requesterId, createdAt])
  @@index([requesterEmail, createdAt])
}

model PlatformThrottle {
  id          String   @id @default(cuid())
  actorUserId String
  targetType  String
  targetId    String
  throttleKey String
  status      String   @default("ACTIVE")
  reason      String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  actor       User     @relation("PlatformThrottleActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, status])
  @@index([throttleKey, status])
  @@index([expiresAt])
}





