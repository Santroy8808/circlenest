generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipTier {
  FREE
  CONTRIBUTOR
  PROFESSIONAL
  AUDITOR
  ORG
}

enum MembershipSubscriptionStatus {
  NONE
  INCOMPLETE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum StripeIntegrationMode {
  TEST
  LIVE
}

enum StripeCheckoutKind {
  SUBSCRIPTION
  CREDIT_PURCHASE
}

enum PromotionAccessScope {
  GLOBAL
  USER
}

enum UserRole {
  MEMBER
  ADMIN
}

enum LogLevel {
  debug
  info
  warn
  error
}

enum AuditSeverity {
  info
  warning
  critical
}

enum ModuleHealthStatus {
  healthy
  degraded
  offline
  unknown
}

enum MediaVisibility {
  PRIVATE
  MEMBERS
  PUBLIC
}

enum MediaCollectionType {
  ALBUM
  TAG
  SYSTEM_DATE
}

enum FeedVisibility {
  MEMBERS
  FRIENDS
  PRIVATE
}

enum FeedReactionType {
  LIKE
  LOVE
  CARE
  HAHA
  WOW
  SAD
  ANGRY
}

enum SocialRelationshipType {
  FRIEND
  FAMILY
  CONTACT
  FOLLOW
  BLOCK
  MUTE
}

enum FamilyRelationshipRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

enum FriendRelationshipRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

enum ChatThreadType {
  DIRECT
  GROUP
}

enum ChatAttachmentKind {
  IMAGE
  FILE
}

enum MailDeliveryKind {
  DIRECT
  MASS_INTERNAL
  INQUIRY
}

enum MailRecipientType {
  TO
  CC
  BCC
}

enum MailAttachmentKind {
  IMAGE
  FILE
}

enum GroupVisibility {
  PUBLIC
  PRIVATE
}

enum GroupJoinPolicy {
  OPEN
  APPROVAL
}

enum GroupMemberRole {
  MEMBER
  MODERATOR
  OWNER
}

enum GroupJoinRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELED
}

enum GroupForumReactionType {
  LIKE
  LOVE
  CARE
  HAHA
  WOW
  SAD
  ANGRY
}

enum GroupAssetKind {
  PHOTO
  DOCUMENT
}

enum EventStatus {
  PUBLISHED
  CANCELED
  ENDED
}

enum EventModeratorRole {
  OWNER
  MODERATOR
}

enum EventInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELED
}

enum EventRsvpStatus {
  GOING
  MAYBE
  DECLINED
}

enum BusinessProfileKind {
  BUSINESS
  ORG
}

enum MarketListingCategory {
  BOOKS_MATERIALS
  COURSE_SUPPLIES
  AUDITING_SUPPLIES
  E_METERS
  FURNITURE_EQUIPMENT
  SERVICES
  BUSINESS_SERVICES
  EVENTS_SUPPLIES
  OTHER
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  ARCHIVED
}

enum JobCategory {
  ADMINISTRATION
  TECHNICAL
  SALES
  DELIVERY
  AUDITING
  TRAINING
  CREATIVE
  PROFESSIONAL_SERVICES
  OTHER
}

enum JobEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMPORARY
  VOLUNTEER
}

enum JobListingStatus {
  ACTIVE
  FILLED
  ARCHIVED
}

enum BusinessInquiryStatus {
  NEW
  READ
  ARCHIVED
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
}

enum AdPlacement {
  RIGHT_STREAM
  BUSINESS_SPOTLIGHT
  RESERVED_STREAM
}

enum AdDestinationKind {
  STOREFRONT
  MARKET_LISTING
  BUSINESS_ARTICLE
  EXTERNAL_URL
}

enum AdDeliveryEventType {
  IMPRESSION
  CLICK
}

enum InterestCategory {
  AUDITING
  TRAINING
  EVENTS
  MARKET
  JOBS
  BUSINESS
  WRITERS
  FUNDRAISERS
  GROUPS
  FAMILY_COMMUNITY
  TECH
  COURSE_SUPPLIES
}

enum PlatformActivityEventType {
  PAGE_VIEW
  HEARTBEAT
  NAVIGATION
  ACTION
  SEARCH
  AD_INTERACTION
  SESSION_START
  SESSION_END
}

enum PlatformCostSubject {
  MARKET_PRODUCT_LISTING
  MARKET_PRODUCT_EXTRA_LISTING
  MARKET_PRODUCT_RENEW
  MARKET_PRODUCT_BOOST
  MARKET_SERVICE_POST
  MARKET_SERVICE_BOOST
  MONTHLY_SPECIAL
  MAIN_STREAM_PROMOTED_POST
  MAIL_SPONSORED_INTERNAL
  AD_RIGHT_BILLBOARD_SMALL
  AD_RIGHT_BILLBOARD_MEDIUM
  AD_RIGHT_BILLBOARD_LARGE
  AD_BUSINESS_SPOTLIGHT
  AD_RESERVED_STREAM
  POST_BOOST
  EVENT_BOOST
  STOREFRONT_SPOTLIGHT
}

enum FundraiserCategory {
  COMMUNITY_PROJECT
  EVENT_SUPPORT
  MATERIALS_SUPPLIES
  EMERGENCY_SUPPORT
  OTHER
}

enum FundraiserStatus {
  ACTIVE
  PAUSED
  ENDED
  ARCHIVED
}

enum FundContributionStatus {
  PLEDGED
  PROCESSOR_PENDING
  PROCESSOR_CONFIRMED
  CANCELED
  REFUNDED
}

enum FundLedgerEntryType {
  PROCESSOR_CONFIRMED_CONTRIBUTION
  PROCESSOR_REFUND
  WITHDRAWAL_BATCH_CAPTURE
}

enum ManuscriptVisibility {
  PRIVATE
  MEMBERS
}

enum AuthSecurityEventType {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  SIGNUP_CREATED
  EMAIL_VERIFICATION_REQUESTED
  EMAIL_VERIFIED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  SESSION_REVOKED
  TWO_FACTOR_READY
}

enum FeedbackTicketStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

enum FeedbackTicketSeverity {
  low
  normal
  high
  urgent
}

enum ProfileVisibility {
  PRIVATE
  MEMBERS
  PUBLIC
}

enum ScientologyVisibility {
  PRIVATE
  MEMBERS
}

enum ScientologyClassification {
  PUBLIC
  STAFF
  SEA_ORG
  AUDITOR
}

model User {
  id                              String                             @id @default(cuid())
  email                           String                             @unique
  username                        String                             @unique
  passwordHash                    String?
  role                            UserRole                           @default(MEMBER)
  emailVerified                   DateTime?
  deactivatedAt                   DateTime?
  sessionVersion                  Int                                @default(1)
  failedLoginCount                Int                                @default(0)
  lastLoginAt                     DateTime?
  lastPasswordChangedAt           DateTime?
  sessionsRevokedAt               DateTime?
  onboardingCompletedAt           DateTime?
  profileOnboardingSkippedAt      DateTime?
  scientologyOnboardingSkippedAt  DateTime?
  termsAcceptedAt                 DateTime?
  goodStandingDeniedAt            DateTime?
  createdAt                       DateTime                           @default(now())
  updatedAt                       DateTime                           @updatedAt
  profile                         Profile?
  scientologyProfile              ScientologyProfile?
  membership                      Membership?
  mediaAssets                     MediaAsset[]
  mediaCollections                MediaCollection[]
  feedPosts                       FeedPost[]                         @relation("FeedPostAuthor")
  feedComments                    FeedComment[]                      @relation("FeedCommentAuthor")
  feedPostReactions               FeedPostReaction[]
  feedCommentReactions            FeedCommentReaction[]
  feedPostDismissals              FeedPostDismissal[]
  galleryAssetComments            GalleryAssetComment[]              @relation("GalleryAssetCommentAuthor")
  socialRelationshipsFrom         SocialRelationship[]               @relation("SocialRelationshipFrom")
  socialRelationshipsTo           SocialRelationship[]               @relation("SocialRelationshipTo")
  familyRequestsSent              FamilyRelationshipRequest[]        @relation("FamilyRequestRequester")
  familyRequestsReceived          FamilyRelationshipRequest[]        @relation("FamilyRequestTarget")
  friendRequestsSent              FriendRelationshipRequest[]        @relation("FriendRequestRequester")
  friendRequestsReceived          FriendRelationshipRequest[]        @relation("FriendRequestTarget")
  devices                         UserDevice[]
  encryptedChatParticipants       EncryptedChatParticipant[]
  encryptedChatMessages           EncryptedChatMessage[]             @relation("EncryptedChatMessageSender")
  encryptedChatEnvelopes          EncryptedChatEnvelope[]            @relation("EncryptedChatEnvelopeRecipient")
  createdChatThreads              ChatThread[]                       @relation("ChatThreadCreator")
  chatParticipants                ChatParticipant[]
  chatMessages                    ChatMessage[]                      @relation("ChatMessageSender")
  createdMailThreads              MailThread[]                       @relation("MailThreadCreator")
  sentMailMessages                MailMessage[]                      @relation("MailMessageSender")
  mailRecipients                  MailRecipient[]
  ownedMailContacts               MailContact[]                      @relation("MailContactOwner")
  contactMailEntries              MailContact[]                      @relation("MailContactUser")
  mailPreference                  MailPreference?
  mailSenderOptOuts               MailSenderOptOut[]                 @relation("MailOptOutOwner")
  mailSenderBlocks                MailSenderOptOut[]                 @relation("MailOptOutSender")
  businessArticles                BusinessArticle[]
  createdGroups                   Group[]                            @relation("GroupCreator")
  groupMemberships                GroupMember[]
  groupJoinRequests               GroupJoinRequest[]                 @relation("GroupJoinRequester")
  reviewedGroupJoinRequests       GroupJoinRequest[]                 @relation("GroupJoinReviewer")
  groupPins                       GroupUserPin[]
  groupForumThreads               GroupForumThread[]                 @relation("GroupForumThreadAuthor")
  endedGroupForumThreads          GroupForumThread[]                 @relation("GroupForumThreadEnder")
  deletedGroupForumThreads        GroupForumThread[]                 @relation("GroupForumThreadDeleter")
  groupForumPosts                 GroupForumPost[]                   @relation("GroupForumPostAuthor")
  groupForumThreadReactions       GroupForumThreadReaction[]
  groupForumPostReactions         GroupForumPostReaction[]
  uploadedGroupAssets             GroupAsset[]                       @relation("GroupAssetUploader")
  groupAssetComments              GroupAssetComment[]                @relation("GroupAssetCommentAuthor")
  createdEvents                   Event[]                            @relation("EventCreator")
  eventModerations                EventModerator[]
  eventInvitationsSent            EventInvitation[]                  @relation("EventInvitationSender")
  eventInvitationsReceived        EventInvitation[]                  @relation("EventInvitationInvitee")
  eventRsvps                      EventRsvp[]
  marketListings                  MarketListing[]                    @relation("MarketListingSeller")
  jobListings                     JobListing[]                       @relation("JobListingEmployer")
  auditorProfile                  AuditorProfile?
  businessProfile                 BusinessProfile?                   @relation("BusinessProfileOwner")
  adCampaigns                     AdCampaign[]                       @relation("AdCampaignOwner")
  adCreditLedgerEntries           AdCreditLedgerEntry[]
  adDeliveryLogs                  AdDeliveryLog[]                    @relation("AdDeliveryViewer")
  fundraiserCampaigns             FundraiserCampaign[]               @relation("FundraiserCreator")
  fundContributionIntents         FundContributionIntent[]           @relation("FundContributionContributor")
  manuscripts                     WriterManuscript[]                 @relation("WriterManuscriptAuthor")
  writerManuscriptSubscriptions   WriterManuscriptSubscription[]
  notifications                   Notification[]
  alerts                          Alert[]
  diagnostics                     DiagnosticLog[]
  auditLogs                       AuditLog[]                         @relation("AuditActor")
  adminActions                    AdminAction[]                      @relation("AdminActionActor")
  updatedPlatformCostRules        PlatformCostRule[]                 @relation("PlatformCostRuleUpdater")
  platformActivityEvents          PlatformActivityEvent[]            @relation("PlatformActivityUser")
  applicationUsageMetric          UserApplicationUsageMetric?
  interests                       UserInterest[]
  authSecurityEvents              AuthSecurityEvent[]
  emailVerificationTokens         EmailVerificationToken[]
  passwordResetTokens             PasswordResetToken[]
  twoFactorConfig                 TwoFactorConfig?
  feedbackTickets                 FeedbackTicket[]                   @relation("FeedbackReporter")
  membershipOverrides             MembershipPolicyOverride[]         @relation("MembershipOverrideSubject")
  createdMembershipOverrides      MembershipPolicyOverride[]         @relation("MembershipOverrideCreator")
  promotionGrants                 MembershipPromotionGrant[]         @relation("PromotionGrantUser")
  createdPromotionGrants          MembershipPromotionGrant[]         @relation("PromotionGrantCreator")
  tierUpgradeEligibilities        MembershipTierUpgradeEligibility[] @relation("TierUpgradeEligibilityUser")
  createdTierUpgradeEligibilities MembershipTierUpgradeEligibility[] @relation("TierUpgradeEligibilityCreator")
  generatedFreeInvites            FreeAccountInviteCode[]            @relation("FreeInviteGeneratedBy")
  assignedFreeInvites             FreeAccountInviteCode[]            @relation("FreeInviteAssignedUser")
  usedFreeInvites                 FreeAccountInviteCode[]            @relation("FreeInviteUsedBy")
}

model UserDevice {
  id                    String                  @id @default(cuid())
  userId                String
  deviceId              String
  publicKey             String
  platform              String                  @default("android")
  appVersion            String?
  lastSeenAt            DateTime                @default(now())
  revokedAt             DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentEncryptedMessages EncryptedChatMessage[]
  receivedChatEnvelopes EncryptedChatEnvelope[]

  @@unique([userId, deviceId])
  @@index([deviceId])
  @@index([userId, revokedAt, lastSeenAt])
}

model Profile {
  id          String            @id @default(cuid())
  userId      String            @unique
  displayName String?
  tagline     String?
  bio         String?
  avatarUrl   String?
  bannerUrl   String?
  location    String?
  visibility  ProfileVisibility @default(MEMBERS)
  theme       Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScientologyProfile {
  id                    String                    @id @default(cuid())
  userId                String                    @unique
  classification        ScientologyClassification @default(PUBLIC)
  orgName               String?
  lastServiceName       String?
  lastServiceAt         DateTime?
  iasMembershipLast6    String?
  trainingLevel         String?
  processingStatus      String?
  courseCompletions     Json?
  introServices         Json?
  technicalCourses      Json?
  specialistCourses     Json?
  additionalProcessing  Json?
  goodStandingAttested  Boolean                   @default(false)
  goodStandingUpdatedAt DateTime?
  educationNotes        String?
  visibility            ScientologyVisibility     @default(PRIVATE)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  user                  User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  commendations         ScientologyCommendation[]
}

model ScientologyCommendation {
  id                   String             @id @default(cuid())
  scientologyProfileId String
  mediaAssetId         String             @unique
  title                String?
  isFlattenedPdf       Boolean            @default(false)
  createdAt            DateTime           @default(now())
  profile              ScientologyProfile @relation(fields: [scientologyProfileId], references: [id], onDelete: Cascade)
  mediaAsset           MediaAsset         @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@index([scientologyProfileId, createdAt])
}

model Membership {
  id                            String                       @id @default(cuid())
  userId                        String                       @unique
  tier                          MembershipTier               @default(FREE)
  inviteEligibleAt              DateTime?
  storageLimitBytes             BigInt                       @default(104857600)
  platformCredits               Int                          @default(0)
  stripeCustomerId              String?
  stripeSubscriptionId          String?                      @unique
  subscriptionStatus            MembershipSubscriptionStatus @default(NONE)
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean                      @default(false)
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  user                          User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([subscriptionStatus, updatedAt])
}

model MembershipTierUpgradeEligibility {
  id              String         @id @default(cuid())
  userId          String
  tier            MembershipTier
  reason          String?
  active          Boolean        @default(true)
  expiresAt       DateTime?
  createdByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation("TierUpgradeEligibilityUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?          @relation("TierUpgradeEligibilityCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, tier])
  @@index([tier, active, expiresAt])
  @@index([createdByUserId, createdAt])
}

model MembershipPromotionGrant {
  id              String               @id @default(cuid())
  scope           PromotionAccessScope @default(USER)
  userId          String?
  sourceTier      MembershipTier       @default(FREE)
  targetTier      MembershipTier
  label           String
  reason          String?
  active          Boolean              @default(true)
  startsAt        DateTime             @default(now())
  expiresAt       DateTime
  createdByUserId String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User?                @relation("PromotionGrantUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy       User?                @relation("PromotionGrantCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([scope, sourceTier, targetTier, active, startsAt, expiresAt])
  @@index([userId, active, startsAt, expiresAt])
}

model FreeAccountInviteCode {
  id                String    @id @default(cuid())
  codeHash          String    @unique
  codePreview       String
  recipientEmail    String?
  assignedUserId    String?
  generatedByUserId String?
  usedByUserId      String?
  emailedAt         DateTime?
  usedAt            DateTime?
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  assignedUser      User?     @relation("FreeInviteAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  generatedBy       User?     @relation("FreeInviteGeneratedBy", fields: [generatedByUserId], references: [id], onDelete: SetNull)
  usedBy            User?     @relation("FreeInviteUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([recipientEmail, expiresAt])
  @@index([assignedUserId, expiresAt])
  @@index([usedAt, expiresAt])
  @@index([generatedByUserId, createdAt])
}

model SubscriptionPlanRule {
  id                    String         @id @default(cuid())
  tier                  MembershipTier @unique
  displayName           String
  standardPriceCents    Int
  stripePriceId         String?
  founderPriceCents     Int?
  founderMemberCap      Int?
  founderWindowDays     Int?
  monthlyCreditBudget   Int            @default(0)
  populationCreditTiers Json?
  active                Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model StripeIntegrationConfig {
  id                          String                @id @default("default")
  mode                        StripeIntegrationMode @default(TEST)
  publishableKey              String?
  secretKey                   String?
  webhookSecret               String?
  currency                    String                @default("usd")
  subscriptionCheckoutEnabled Boolean               @default(true)
  creditCheckoutEnabled       Boolean               @default(false)
  updatedByUserId             String?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt

  @@index([updatedByUserId, updatedAt])
}

model StripeCreditPackage {
  id            String   @id @default(cuid())
  key           String   @unique
  label         String
  description   String?
  creditAmount  Int
  priceCents    Int
  stripePriceId String?
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([active, sortOrder])
}

model StripeCheckoutFulfillment {
  id                      String             @id @default(cuid())
  stripeCheckoutSessionId String             @unique
  userId                  String
  kind                    StripeCheckoutKind
  creditPackageKey        String?
  creditsGranted          Int?
  createdAt               DateTime           @default(now())

  @@index([userId, createdAt])
}

model AdExperienceRule {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  value       Int
  unit        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DiagnosticLog {
  id        String   @id @default(cuid())
  level     LogLevel
  module    String
  message   String
  context   Json?
  requestId String?
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([module, createdAt])
  @@index([level, createdAt])
}

model AuditLog {
  id          String        @id @default(cuid())
  actorUserId String?
  module      String
  action      String
  targetType  String?
  targetId    String?
  severity    AuditSeverity @default(info)
  metadata    Json?
  createdAt   DateTime      @default(now())
  actor       User?         @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([module, action, createdAt])
  @@index([actorUserId, createdAt])
}

model PlatformActivityEvent {
  id            String                    @id @default(cuid())
  userId        String?
  sessionKey    String?
  eventType     PlatformActivityEventType
  route         String?
  module        String?
  action        String?
  targetType    String?
  targetId      String?
  metadata      Json?
  ipHash        String?
  userAgentHash String?
  createdAt     DateTime                  @default(now())
  user          User?                     @relation("PlatformActivityUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([route, createdAt])
  @@index([module, action, createdAt])
}

model UserApplicationUsageMetric {
  id                                  String   @id @default(cuid())
  userId                              String   @unique
  mobileActivityScore                 Float    @default(0)
  desktopActivityScore                Float    @default(0)
  reservedStreamOrganicUnits          Int      @default(0)
  reservedStreamAdImpressions         Int      @default(0)
  reservedStreamOrganicUnitsAtLastAd  Int      @default(0)
  lastSeenAt                          DateTime?
  lastMobileSeenAt                    DateTime?
  lastDesktopSeenAt                   DateTime?
  lastReservedStreamAdAt              DateTime?
  createdAt                           DateTime @default(now())
  updatedAt                           DateTime @updatedAt
  user                                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lastSeenAt])
  @@index([lastMobileSeenAt])
  @@index([lastDesktopSeenAt])
}

model UserInterest {
  id        String           @id @default(cuid())
  userId    String
  category  InterestCategory
  source    String           @default("self")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([category])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ModuleHealthCheck {
  id        String             @id @default(cuid())
  module    String             @unique
  status    ModuleHealthStatus @default(unknown)
  message   String?
  checkedAt DateTime           @default(now())
  metadata  Json?
}

model AdminAction {
  id          String   @id @default(cuid())
  actorUserId String?
  actionKey   String
  module      String
  status      String
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation("AdminActionActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actionKey, createdAt])
  @@index([actorUserId, createdAt])
}

model PublicAnnouncement {
  id                       String   @id @default(cuid())
  createdByUserId          String
  title                    String
  body                     String
  audienceKind             String
  audienceValue            String?
  channels                 String[] @default([])
  recipientCount           Int      @default(0)
  chatDeliveryCount        Int      @default(0)
  mailDeliveryCount        Int      @default(0)
  popupDeliveryCount       Int      @default(0)
  globalPostDeliveryCount  Int      @default(0)
  personalEmailQueuedCount Int      @default(0)
  feedPostId               String?
  metadata                 Json?
  createdAt                DateTime @default(now())

  @@index([createdByUserId, createdAt])
  @@index([audienceKind, createdAt])
}

model MediaAsset {
  id                      String                   @id @default(cuid())
  ownerUserId             String
  storageKey              String                   @unique
  publicUrl               String?
  mimeType                String
  sizeBytes               BigInt
  originalName            String?
  visibility              MediaVisibility          @default(PRIVATE)
  metadata                Json?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  owner                   User                     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  collections             MediaCollectionAsset[]
  feedPosts               FeedPost[]
  feedComments            FeedComment[]
  galleryComments         GalleryAssetComment[]
  adCampaignImages        AdCampaign[]             @relation("AdCampaignImage")
  businessArticleCovers   BusinessArticle[]        @relation("BusinessArticleCover")
  chatAttachments         ChatAttachment[]
  mailAttachments         MailAttachment[]
  groupForumPosts         GroupForumPost[]
  groupAssets             GroupAsset[]
  marketListingPhotos     MarketListingPhoto[]
  scientologyCommendation ScientologyCommendation?

  @@index([ownerUserId, createdAt])
}

model GalleryAssetComment {
  id           String     @id @default(cuid())
  mediaAssetId String
  authorUserId String
  body         String
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
