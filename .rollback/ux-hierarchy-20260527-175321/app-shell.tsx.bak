import Image from "next/image";
import Link from "next/link";
import { auth } from "@/auth";
import { prisma } from "@/lib/db/prisma";
import { MobileBottomNav } from "@/components/layout/mobile-bottom-nav";
import { LogoutButton } from "@/components/layout/logout-button";
import { CommunicateLauncher } from "@/components/layout/communicate-launcher";

export async function AppShell({ children, rightSidebar }: { children: React.ReactNode; rightSidebar?: React.ReactNode }) {
  const session = await auth();
  const userId = session?.user?.id;

  const [profile, counts] = userId
    ? await Promise.all([
        prisma.profile.findUnique({ where: { userId }, select: { displayName: true, avatarUrl: true, bannerUrl: true } }),
        Promise.all([
          prisma.notification.count({ where: { userId, readAt: null } }),
          prisma.message.count({ where: { thread: { OR: [{ userAId: userId }, { userBId: userId }] }, readAt: null, senderId: { not: userId } } }),
          prisma.friendRequest.count({ where: { receiverId: userId, status: "PENDING" } }),
        ]),
      ])
    : [null, [0, 0, 0]];

  const [unreadNotifications, unreadMessages, pendingInvites] = counts;

  return (
    <div className="min-h-screen pb-14 md:pb-0">
      <div className="mx-auto hidden max-w-[1500px] grid-cols-[220px_minmax(0,1fr)] gap-2 p-2 min-[700px]:grid xl:grid-cols-[220px_minmax(0,1fr)_260px]">
        <aside className="card sticky top-2 h-[calc(100vh-1rem)] overflow-auto p-2">
          <div className="mb-2 flex items-start gap-2">
            <div className="flex items-start gap-2">
              <div className="relative h-[7.5rem] w-[7.5rem] overflow-hidden rounded-md border border-[var(--border)]">
                {profile?.avatarUrl ? (
                  <Image src={profile.avatarUrl} alt="Avatar" width={160} height={160} className="h-full w-full pointer-events-none object-cover" priority={false} />
                ) : <div className="h-full w-full bg-[#222b3d]" />}
              </div>
              <div>
                <p className="text-sm font-semibold text-[var(--text-strong)]">CircleNest</p>
                <Link href="/home" className="text-xs text-slate-300 hover:underline">My Stream</Link>
              </div>
            </div>
          </div>

          <nav className="space-y-2 text-xs">
            <Section title="Home" links={[["Profile", "/profile/edit"], ["Gallery", "/profile/gallery"], ["Theme", "/settings/theme"]]} />
            <Section title="Communications" links={[["Messages", "/messages"], ["Notifications", "/notifications"], ["Invites", "/friends#invites"]]} />
            <Section title="People" links={[["Friends", "/friends"], ["Groups", "/groups"], ["My Groups", "/groups?mine=1"]]} />
            <Section title="Settings" links={[["Security", "/settings"], ["Theme", "/settings/theme"], ["My Rules", "/settings#rules"], ["My Subscription", "/settings#subscription"]]} />
          </nav>
          <div className="mt-2 border-t border-[var(--border)] pt-2">
            <LogoutButton />
          </div>
        </aside>

        <main className="space-y-2">
          <div className="relative h-48 overflow-hidden rounded-md border border-[var(--border)]">
            {profile?.bannerUrl ? (
              <Image src={profile.bannerUrl} alt="Banner" width={1200} height={320} className="h-full w-full object-cover" priority={false} />
            ) : <div className="h-full w-full bg-gradient-to-r from-[#1b2438] to-[#0b0e15]" />}
          </div>
          <header className="px-1 py-0.5 text-xs">
            <div className="flex items-center justify-between gap-3">
              <div className="flex flex-wrap items-center gap-3 text-[13px]">
                <Link href="/notifications?type=all" className="hover:underline">All</Link>
                <Link href="/notifications?type=messages" className="hover:underline">{`\u{1F4AC}`} {unreadMessages}</Link>
                <Link href="/notifications" className="hover:underline">{`\u{1F514}`} {unreadNotifications}</Link>
                <Link href="/friends#invites" className="hover:underline">{`\u{1F4E8}`} {pendingInvites}</Link>
                <Link href="/home" className="underline-offset-2 hover:underline">My Stream</Link>
                <Link href="/friends" className="underline-offset-2 hover:underline">Friends</Link>
                <Link href="/profile/gallery" className="underline-offset-2 hover:underline">Gallery</Link>
                <Link href="/messages" className="underline-offset-2 hover:underline">Messages</Link>
                <Link href="/groups" className="underline-offset-2 hover:underline">Groups</Link>
              </div>
              <CommunicateLauncher />
            </div>
          </header>
          {children}
        </main>

        <aside className="card sticky top-2 hidden h-[calc(100vh-1rem)] overflow-auto p-2 text-xs xl:block">
          {rightSidebar ?? <p className="text-slate-400">Right panel reserved for ad stream and quick tools.</p>}
        </aside>
      </div>

      <div className="space-y-2 p-2 min-[700px]:hidden">{children}</div>
      <MobileBottomNav />
    </div>
  );
}

function Section({ title, links }: { title: string; links: [string, string][] }) {
  return (
    <section className="border-t border-[var(--border)] pt-2">
      <p className="mb-1 text-[11px] font-semibold uppercase tracking-[0.2em] text-[var(--text-strong)]">{title}</p>
      <div className="grid gap-0.5">
        {links.map(([label, href]) => (
          <Link key={href} href={href} className="text-[13px] text-slate-300 transition hover:translate-y-[-1px] hover:scale-[1.02] hover:text-white">
            {label}
          </Link>
        ))}
      </div>
    </section>
  );
}
