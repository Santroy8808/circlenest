{
  "name": "theta-space",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/prisma-generate.js && next build",
    "build:netlify": "prisma generate --schema prisma/schema.postgres.prisma && next build",
    "postinstall": "node scripts/prisma-generate.js",
    "start": "next start",
    "lint": "next lint",
    "test:phase1": "tsx scripts/phase1-tier-policy-smoke.ts",
    "test:phase8": "tsx scripts/phase8-acceptance-smoke.ts",
    "db:generate": "node scripts/prisma-generate.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "billing:mock:simulate": "tsx scripts/mock-billing-sim.ts",
    "platform:mock:simulate": "tsx scripts/mock-platform-sim.ts",
    "db:push:pg": "prisma db push --schema prisma/schema.postgres.prisma",
    "db:generate:pg": "prisma generate --schema prisma/schema.postgres.prisma",
    "stable:create": "powershell -ExecutionPolicy Bypass -File ./scripts/stable-point-create.ps1",
    "stable:list": "powershell -ExecutionPolicy Bypass -File ./scripts/stable-point-list.ps1",
    "stable:rollback": "powershell -ExecutionPolicy Bypass -File ./scripts/stable-point-rollback.ps1",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f --tail 200"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@aws-sdk/client-s3": "^3.1056.0",
    "@prisma/client": "^5.16.2",
    "bcryptjs": "^3.0.3",
    "next": "^14.2.35",
    "next-auth": "^5.0.0-beta.20",
    "nodemailer": "^6.10.1",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sanitize-html": "^2.13.0",
    "sharp": "^0.33.5",
    "speakeasy": "^2.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/speakeasy": "^2.0.10",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "playwright": "^1.60.0",
    "postcss": "^8.4.39",
    "prisma": "^5.16.2",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4"
  }
}
