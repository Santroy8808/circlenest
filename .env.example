DATABASE_URL="file:./dev.db"
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Feature flags for controlled rebuild cutover
FEATURE_REBUILD_CORE="true"
FEATURE_REBUILD_GROUPS="true"
FEATURE_REBUILD_MESSAGING="true"
FEATURE_REBUILD_NOTIFICATIONS="true"
FEATURE_REBUILD_ALERTS="true"

# SMTP (PrivateEmail example)
SMTP_HOST="mail.privateemail.com"
SMTP_PORT="465"
SMTP_USER="mike@dearmon.net"
SMTP_PASS="replace-with-password"
SMTP_FROM="mike@dearmon.net"

# Docker/Postgres profile
POSTGRES_USER="circlenest"
POSTGRES_PASSWORD="circlenest"
POSTGRES_DB="circlenest"

# Object storage (MinIO/S3)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_BUCKET="circlenest-media"
MINIO_ROOT_USER="minioadmin"
MINIO_ROOT_PASSWORD="minioadmin"

# Account-level crypto and admin escrow
# 32-byte random key, base64-encoded
SYSTEM_MASTER_KEY_BASE64=""
# PEM-encoded public key for admin escrow wrapping
SYSTEM_ADMIN_PUBLIC_KEY_PEM=""
